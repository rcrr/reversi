>>> from twolm.domain import *
>>> from twolm.rdata import *
>>> rc = RegabDBConnection('tst_regab', 'tst_regab', 'database_host.local', '5432')
>>> rds = RegabDataSet.extract_from_db(rc, [8], ['CMS', 'CMR'], 20)
>>> rds.length
200
>>> rds.store_to_file('build/tmp/ragab_data_file_200pos_ec20.dat')
>>> 