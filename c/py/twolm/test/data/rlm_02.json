{
    "name": "RGLM (Logistic) - Unit Test 02 (rlm_02.json)",
    "description": "Used for unit testing the gradient worker.",
    "base_dir": "will/be/overwritten/by/python/during/unittesting",
    "use_cache": true,
    "stat_model": {
        "frequency_cut_off": 1,
        "logit_clipping": 0.01,
        "ridge_regularization": 0.01,
    },
    "optimization": {
        "max_iters": 500,
        "m": 50,
        "c1": 0.0001,
        "c2": 0.9,
        "min_grad": [1e-10, 3],
        "min_p_fun_decrease": [1e-14, 7],
        "log_every_n": 1,
        "save_every_n": 0
    },
    "regab_data_set": {
        "regab_db_connection": {
            "dbname": "tst_regab",
            "user": "tst_regab",
            "host": "localhost"
        },
        "bid": [6, 7],
        "status": ["CMR", "CMS"],
        "ec": 20
    },
    "feature_set": {
        "intercept": false,
        "pattern_set": {
            "name": "Edge_Diag3",
            "patterns": [
                { "name": "DIAG3", "mask": "0000000000010204" },
                { "name": "EDGE",  "mask": "00000000000000FF" }
            ]
        },
        "mobility_set": {
            "name": "BasicMobilitySet",
            "mobility_features": [
            ]
        }
    }
}
