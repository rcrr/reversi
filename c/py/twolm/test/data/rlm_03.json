{
    "name": "RGLM (Logistic) - Long Test 03 (rlm_03.json)",
    "description": "Used for long testing the optimize worker.",
    "base_dir": "will/be/overwritten/by/python/during/unittesting",
    "use_cache": true,
    "stat_model": {
        "frequency_cut_off": 1,
        "logit_clipping": 0.01,
        "ridge_regularization": 0.01,
    },
    "optimization": {
        "max_iters": 600,
        "m": 93,
        "c1": 0.0001,
        "c2": 0.9,
        "min_grad": [1e-5, 5],
        "min_p_fun_decrease": [1e-6, 5],
        "log_every_n": 1,
        "save_every_n": 100
    },
    "regab_data_set": {
        "regab_db_connection": {
            "dbname": "tst_regab",
            "user": "tst_regab",
            "host": "localhost"
        },
        "bid": [3],
        "status": ["CMR", "CMS"],
        "ec": 20
    },
    "feature_set": {
        "intercept": false,
        "pattern_set": {
            "name": "A2050",
            "patterns": [
                { "name": "XEDGE",  "mask": "00000000000042FF" },
                { "name": "CORNER", "mask": "0000000000070707" },
                { "name": "R2",     "mask": "000000000000FF00" },
                { "name": "R3",     "mask": "0000000000FF0000" },
                { "name": "R4",     "mask": "00000000FF000000" },
                { "name": "DIAG4",  "mask": "0000000001020408" },
                { "name": "DIAG5",  "mask": "0000000102040810" },
                { "name": "DIAG6",  "mask": "0000010204081020" },
                { "name": "DIAG7",  "mask": "0001020408102040" },
                { "name": "DIAG8",  "mask": "0102040810204080" },
                { "name": "2X5COR", "mask": "0000000000001F1F" }
            ]
        },
        "mobility_set": {
            "name": "BasicMobilitySet",
            "mobility_features": [
                { "name": "LMC", "mask": "FFFFFFFFFFFFFFFF", "amask": "0000000000000000" }
            ]
        }
    }
}
